import base64

def base64url_decode(payload):
    # Añade el padding '=' dinámicamente según el residuo de la longitud
    rem = len(payload) % 4
    if rem > 0:
        payload += "=" * (4 - rem)
    # Reemplaza caracteres de Base64URL a Base64 estándar antes de decodificar
    return base64.urlsafe_b64decode(payload.encode('utf-8')).decode('utf-8')

def base64url_encode(payload):
    # Codifica a Base64URL y elimina los caracteres '=' de padding
    encoded = base64.urlsafe_b64encode(payload.encode('utf-8')).decode('utf-8')
    return encoded.rstrip("=")

